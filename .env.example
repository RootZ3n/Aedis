# Aedis local configuration example.
# Copy to .env for local use.
#
# WARNING: Never commit .env or real provider keys to git.
# .gitignore already excludes .env — do not override that.

# ── Server ────────────────────────────────────────────────────────────

AEDIS_HOST=0.0.0.0
AEDIS_PORT=18796

# Target repo Aedis operates on. Defaults to current working directory
# if unset. Set this to avoid accidentally targeting the wrong repo.
AEDIS_PROJECT_ROOT=/path/to/target/repo

AEDIS_AUTO_PROMOTE=false
AEDIS_STRICT_MODE=false
AEDIS_VISION=false

# ── Auth ──────────────────────────────────────────────────────────────

# Auth is ENABLED by default (requires Tailscale identity).
# Set to true to DISABLE auth for local-only development.
TAILSCALE_ONLY=true

# ── CLI ───────────────────────────────────────────────────────────────

AEDIS_API_BASE=http://127.0.0.1:18796

# ── Workspace/runtime ─────────────────────────────────────────────────

AEDIS_TMPDIR=/tmp

# Runtime receipts, task index, and recovery metadata. Keep this in the
# Aedis install/runtime directory, not inside the target source repo.
AEDIS_STATE_ROOT=

# ── Provider keys (REQUIRED for default config) ──────────────────────
# The default model config uses OpenRouter (builder, coordinator) and
# Z.ai (integrator, escalation). You MUST set these for tasks to run.

OPENROUTER_API_KEY=
ZAI_API_KEY=

# ── Provider keys (OPTIONAL) ─────────────────────────────────────────
# Only needed if you override the default model config or want to use
# these providers in your .aedis/model-config.json fallback chains.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MINIMAX_API_KEY=
MODELSTUDIO_API_KEY=

# ── Ollama (REQUIRED for default config) ──────────────────────────────
# The default critic uses Ollama (qwen3.5:9b) and the prompt normalizer
# uses Ollama (qwen3.5:4b). You must have Ollama installed and running
# with these models pulled. See docs/PROVIDER-SETUP.md for instructions.
#
# Default: http://localhost:11434 (standard Ollama port)
OLLAMA_BASE_URL=http://localhost:11434

# ── Optional provider endpoints ───────────────────────────────────────

OPENAI_BASE_URL=https://api.openai.com/v1
MODELSTUDIO_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MINIMAX_BASE_URL=https://api.minimax.chat/v1
ZAI_BASE_URL=https://api.z.ai/api/paas/v4/

# ── Optional model overrides ──────────────────────────────────────────

LOQUI_OPENROUTER_MODEL=xiaomi/mimo-v2-pro
LOQUI_OPENAI_MODEL=gpt-4.1-mini
OLLAMA_VISION_MODEL=qwen3-vl:8b
