# Aedis local configuration example.
# Copy to .env for local use. Do not commit real provider keys.

# Server
AEDIS_HOST=0.0.0.0
AEDIS_PORT=18796
AEDIS_PROJECT_ROOT=/path/to/target/repo
AEDIS_AUTO_PROMOTE=false
AEDIS_STRICT_MODE=false
AEDIS_VISION=false

# CLI
AEDIS_API_BASE=http://localhost:18796

# Workspace/runtime
AEDIS_TMPDIR=/tmp

# Provider keys
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional provider endpoints
OPENAI_BASE_URL=https://api.openai.com/v1
MODELSTUDIO_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MINIMAX_BASE_URL=https://api.minimax.chat/v1
ZAI_BASE_URL=https://api.z.ai/api/paas/v4/
OLLAMA_BASE_URL=http://localhost:11434

# Optional model overrides
LOQUI_OPENROUTER_MODEL=xiaomi/mimo-v2-pro
LOQUI_OPENAI_MODEL=gpt-4.1-mini
OLLAMA_VISION_MODEL=qwen3-vl:8b
