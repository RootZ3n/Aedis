{
  "name": "aedis",
  "version": "1.0.0",
  "description": "Supervised AI build orchestration with receipts, verification, and human approval.",
  "main": "dist/server/index.js",
  "type": "module",
  "files": [
    "dist/",
    "ui/",
    "docs/",
    "README.md",
    ".env.example",
    "CHANGELOG.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "bin": {
    "aedis": "./dist/cli/aedis.js"
  },
  "scripts": {
    "start": "tsx server/index.ts",
    "start:dist": "node dist/server/index.js",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p tsconfig.build.json && node scripts/write-build-info.mjs",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "dev": "npx tsx watch server/index.ts",
    "cli": "tsx cli/aedis.ts",
    "prepack": "npm run build",
    "test": "bash -O globstar -c 'tsx --test --test-concurrency=4 core/**/*.test.{ts,tsx} server/**/*.test.ts workers/**/*.test.ts cli/**/*.test.{ts,tsx} scripts/**/*.test.ts'",
    "test:gauntlet": "tsx --test core/regression-gauntlet.test.ts",
    "smoke": "node scripts/smoke.mjs",
    "tui": "tsx cli/tui/index.tsx",
    "security:secrets": "bash scripts/check-secrets.sh",
    "audit:release": "npm audit --audit-level=moderate",
    "verify:release": "npm run typecheck && npm run build && npm test && npm run security:secrets && npm run smoke",
    "check": "npm run security:secrets && npm test && npm run build && npx tsc -p tsconfig.build.json --noEmit",
    "burn:soft": "npx tsx scripts/burn-in/test-burn-in.ts",
    "burn:hard": "npx tsx scripts/burn-in/test-burn-in-hard.ts"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "ai",
    "build",
    "orchestration",
    "governed"
  ],
  "author": "Zen",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/ws": "^8.18.1",
    "glob": "^13.0.6",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.1.0",
    "@fastify/websocket": "^11.2.0",
    "dotenv": "^16.6.1",
    "fastify": "^5.8.4",
    "ink": "^7.0.1",
    "puppeteer": "^24.40.0",
    "react": "^19.2.5"
  }
}
