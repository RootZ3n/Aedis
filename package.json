{
  "name": "aedis",
  "version": "1.0.0",
  "description": "Build quality without token burn.",
  "main": "dist/server/index.js",
  "type": "module",
  "files": [
    "dist/",
    "ui/",
    "docs/",
    "README.md",
    ".env.example"
  ],
  "bin": {
    "aedis": "./dist/cli/aedis.js"
  },
  "scripts": {
    "start": "tsx server/index.ts",
    "start:dist": "node dist/server/index.js",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "dev": "npx tsx watch server/index.ts",
    "cli": "tsx cli/aedis.ts",
    "prepack": "npm run build",
    "test": "bash -O globstar -c 'tsx --test core/**/*.test.ts server/**/*.test.ts'"
  },
  "keywords": [
    "ai",
    "build",
    "orchestration",
    "governed"
  ],
  "author": "Zen",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/ws": "^8.18.1",
    "glob": "^13.0.6",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.1.0",
    "@fastify/websocket": "^11.2.0",
    "dotenv": "^16.6.1",
    "fastify": "^5.8.4",
    "puppeteer": "^24.40.0"
  }
}
